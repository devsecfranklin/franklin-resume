# You can set TF_LOG to one of the log levels TRACE, DEBUG, INFO, 
# WARN or ERROR to change the verbosity of the logs. TRACE is the
# most verbose and it is the default if TF_LOG is set to something
# other than a log level name.
TF_LOG="TRACE"
TF_LOG_PATH="/tmp/terraform.franklin"

PROJECT_ID="gcp-gcs-pso"
CLOUDSDK_CORE_PROJECT="gcp-gcs-pso"
GOOGLE_REGION="us-central1"
GOOGLE_APPLICATION_CREDENTIALS="${HOME}/.config/gcloud/gcp-gcs-pso-f9322c73b9bf.json"
#GOOGLE_APPLICATION_CREDENTIALS="${HOME}/.config/gcloud/gcp-gcs-pso-6380814298ec.json"

# Run kubectl with the new plugin prior to the release of v1.26
USE_GKE_GCLOUD_AUTH_PLUGIN=False

#
# file location: /etc/krb5kdc/kdc.conf

[kdcdefaults]
    kdc_ports = 750,88
    default_realm = LAB.BITSMASHER.NET
    spake_preauth_kdc_challenge = edwards25519
    pkinit_identity = FILE:/var/lib/krb5kdc/kdccert.pem,/var/lib/krb5kdc/kdckey.pem
    pkinit_anchors = FILE:/etc/krb5/cacert.pem

[libdefaults]
    spake_preauth_groups = edwards25519

[realms]
    LAB.BITSMASHER.NET = {
        database_name = /var/lib/krb5kdc/principal
        admin_keytab = FILE:/var/lib/krb5kdc/kadm5.keytab
        acl_file = /var/lib/krb5kdc/kadm5.acl
        key_stash_file = /var/lib/krb5kdc/stash
        kdc_ports = 750,88
        max_life = 48h 0m 0s
        max_renewable_life = 7d 0h 0m 0s
        #master_key_type = des3-hmac-sha1
        master_key_type = aes256-cts-hmac-sha1-96
        #supported_enctypes = aes256-cts:normal aes128-cts:normal
        #default_principal_flags = +preauth
    }

[logging]
  kdc = FILE:/var/log/kerberos/krb5kdc.log
  admin_server = FILE:/var/log/kerberos/kadmin.log
  default = FILE:/var/log/kerberos/krb5.log

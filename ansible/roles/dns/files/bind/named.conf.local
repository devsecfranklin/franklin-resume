# MANAGED BY ANSIBLE
# /etc/bind/named.conf.local

zone "lab.bitsmasher.net" IN {
  type master;
  file "/etc/bind/db.home.lab";
};

zone "10.10.in-addr.arpa" {
  type master;
  file "/etc/bind/db.rev.0.10.10.in-addr.arpa";
};

zone "dmz.bitsmasher.net" IN {
 type master;
 file "/etc/bind/db.bitsmasher.dmz";
};
$TTL    10800
@ IN SOA server1.core.bitsmasher.net. root.core.bitsmasher.net (
        2024111601 ; serial
        8H ; refresh
        4H ; retry
        4W ; expire
        1D ; minimum
        ) ;
;Name Server Information
@ IN NS server1.core.bitsmasher.net.

;IP address of Your Domain Name Server(DNS)
server1       IN A 10.10.0.12

;A Record for Host names
dream-machine   IN A 10.10.0.1
server3         IN A 10.10.0.13
odroid-c1       IN A 10.10.0.254

$TTL    10800
@ IN SOA server1.lab.bitsmasher.net. root.bitsmasher.net (
        202505191415 ; serial
        8H ; refresh
        4H ; retry
        4W ; expire
        1D ; minimum
        ) ;
;Name Server Information
@ IN NS server1.lab.bitsmasher.net.

;IP address of Your Domain Name Server(DNS)
server1         IN A 10.10.0.12

;A Record for Host names
gateway         IN A 192.168.0.1
dream-machine   IN A 192.168.0.16
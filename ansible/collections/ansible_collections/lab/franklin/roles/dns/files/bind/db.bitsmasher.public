;A Record for Host names
router-a        IN A 10.0.0.1
thelio          IN A 10.0.0.67
;dream-machine   IN A 10.0.0.70 ; still using this IP but extra name not needed
grimoire        IN A 10.0.0.189
femputer        IN A 10.0.0.205

$TTL    10800
@ IN SOA server1.core.bitsmasher.net. root.bitsmasher.net (
        2024111601 ; serial
        8H ; refresh
        4H ; retry
        4W ; expire
        1D ; minimum
        ) ;
;Name Server Information
@ IN NS server1.core.bitsmasher.net.

;IP address of Your Domain Name Server(DNS)

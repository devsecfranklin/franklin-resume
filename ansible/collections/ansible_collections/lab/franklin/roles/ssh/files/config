Host *.lab.bitsmasher.net
   User franklin
   GSSAPIAuthentication yes
   GSSAPIDelegateCredentials yes
   PreferredAuthentications gssapi-keyex,gssapi-with-mic,publickey
   CanonicalizeHostname yes
   CanonicalDomains lab.bitsmasher.net
   CanonicalizeMaxDots 3
   CanonicalizeFallbackLocal yes
   ServerAliveInterval 8860
   ForwardX11 yes                # Enable X11 forwarding for these hosts
   ForwardX11Trusted yes         # (Optional) Use trusted X11 forwarding
   XAuthLocation /usr/bin/xauth # Uncomment and set if xauth is not in default path

Host *
  IdentityAgent ~/.1password/agent.sock

Host github.com
  ServerAliveInterval 86400
  ServerAliveCountMax 4
  IdentityFile ~/.ssh/id_ed25519

# This is the ssh client system-wide configuration file.  See
# ssh_config(5) for more information.  This file provides defaults for
# users, and the values can be changed in per-user configuration files
# or on the command line.

# Configuration data is parsed as follows:
#   1. command line options
#   2. user-specific file
#   3. system-wide file
# Any configuration value is only changed the first time it is set.
# Thus, host-specific definitions should be at the beginning of the
# configuration file, and defaults at the end.

# Site-wide defaults for some commonly used options.  For a comprehensive
# list of available options, their meanings and defaults, please see the
# ssh_config(5) man page.

Include /etc/ssh/ssh_config.d/*.conf

Host *
    # SSH Agent and X11 Forwarding
    ForwardAgent no               # Disable SSH agent forwarding by default for security [1, 2]
    ForwardX11 yes                # Enable X11 forwarding by default
    ForwardX11Trusted yes         # Use trusted X11 forwarding by default (optional, but often useful)

    # Authentication Methods
    PasswordAuthentication yes    # Allow password authentication as a fallback (can be overridden by user)
    GSSAPIAuthentication yes      # Enable GSSAPI (Kerberos) authentication by default [3]
    GSSAPIDelegateCredentials yes # Delegate Kerberos TGT to remote host for multi-hop access [4, 5]
    GSSAPIKeyExchange yes         # Enable GSSAPI key exchange
    GSSAPITrustDNS yes            # Trust DNS for GSSAPI (important for Kerberos SPN resolution)
    PreferredAuthentications gssapi-with-mic,publickey,keyboard-interactive,password # Prioritize GSSAPI [6, 7]

    # Connection Performance and Stability
    ConnectTimeout 10             # Set a timeout for TCP connection establishment to 10 seconds [8, 9]
    ServerAliveInterval 60        # Send keep-alive messages every 60 seconds if no data is received [10, 11]
    ServerAliveCountMax 3         # Disconnect after 3 unanswered keep-alive messages (total 180 seconds) [10, 11]
    Compression yes               # Enable compression for potentially faster transfers over slow links [12, 8, 13]

    # Hostname Canonicalization for Kerberos
    CanonicalizeHostname yes      # Ensure hostnames are canonicalized to FQDNs for Kerberos SPN matching [12, 14, 15, 9, 16, 17]
    CanonicalDomains bitsmasher.net,lab.bitsmasher.net # Domains to search for canonicalization [12, 17]
    CanonicalizeMaxDots 3         # Allow canonicalization for hostnames with up to 3 dots [14, 5, 18]
    CanonicalizeFallbackLocal yes # Fallback to system resolver if explicit canonicalization fails [12, 19, 14, 13, 15, 18]

    # Security Best Practices
    StrictHostKeyChecking yes     # Enforce strict host key checking to prevent MITM attacks [20, 13]
    UpdateHostKeys yes            # Automatically update known_hosts for changed keys [12]
    LogLevel INFO                 # Standard logging level; change to DEBUG/DEBUG1/DEBUG2/DEBUG3 for troubleshooting [8, 21]

    # Connection Multiplexing (improves performance for multiple sessions to same host)
    ControlMaster auto            # Enable automatic connection multiplexing [22, 23, 24, 25, 26, 27, 28]
    ControlPath "~/.ssh/control-%r@%h:%p" # Unique socket path using remote user, host, and port [3, 22, 23, 24, 25, 26, 29, 27, 28]
    ControlPersist 1h             # Keep the master connection alive for 1 hour after last client disconnects [14, 23, 24, 25, 27]

    # Other common settings
    SendEnv LANG LC_*             # Send locale environment variables
    HashKnownHosts yes            # Hash hostnames in known_hosts file for privacy

    IdentityAgent "~/.1password/agent.sock" # IdentityAgent is typically user-specific, but retained as per original input


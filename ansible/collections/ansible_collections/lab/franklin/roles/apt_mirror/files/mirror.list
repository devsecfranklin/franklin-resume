## apt-mirror configuration file
## The following are default configuration options (uncomment the singular # to change)
set base_path /mnt/backup1/apt-mirror
# set mirror_path $base_path/mirror
# set skel_path $base_path/skel
set var_path $base_path/var
# set defaultarch
# set nthreads 20
set _tilde 0##

## sources
deb-armhf http://archive.raspbian.org/raspbian bullseye main contrib non-free rpi
#deb-src http://archive.raspbian.org/raspbian bullseye main contrib non-free rpi firmware
#deb http://plug-mirror.rcac.purdue.edu/raspbian/ bullseye main contrib non-free rpi

## Cleaner configuration example
#set cleanscript $var_path/clean.sh
## Cleaning section
#clean http://security.debian.org/
#clean http://ftp.us.debian.org/
#clean http://plug-mirror.rcac.purdue.edu/

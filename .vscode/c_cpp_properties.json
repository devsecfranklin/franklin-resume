{
  "env": {
    "myIncludePath": [
      "${workspaceFolder}/src/gui-test/src",
      "${workspaceFolder}/src/gui-test/include"
    ],
    "myDefines": [
      "DEBUG",
      "MY_FEATURE=1"
    ]
  },
  "configurations": [
    {
      "name": "linux-gcc-x64",
      "includePath": [
        "${workspaceFolder}/**"
      ],
      "compilerPath": "/usr/bin/gcc",
      "cStandard": "${default}",
      "cppStandard": "${default}",
      "intelliSenseMode": "linux-gcc-x64",
      "compilerArgs": [
        ""
      ]
    }
  ],
  "version": 4
}